# Copy this file to `.env` and fill in the keys you have.
# You only need ONE of these to get started — Gemini is recommended.

# Google AI Studio — get free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — get free key at https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter — get free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: GitHub token for higher clone rate limits
GITHUB_TOKEN=
